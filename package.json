{
  "name": "@russ-b/nestjs-common-tools",
  "version": "2.1.1",
  "description": "NestJS utility tools",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node -e \"const fs = require('fs'); fs.rmSync('dist', { recursive: true, force: true }); fs.rmSync('tsconfig.tsbuildinfo', { force: true });\" && tsc",
    "test": "jest",
    "prepublishOnly": "npm test",
    "prepare": "npm run build",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "nestjs",
    "typeorm",
    "database",
    "tools"
  ],
  "author": "RuSS-B",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RuSS-B/nestjs-common-tools.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./pagination": {
      "types": "./dist/pagination/index.d.ts",
      "default": "./dist/pagination/index.js"
    },
    "./common/util": {
      "types": "./dist/common/util/index.d.ts",
      "default": "./dist/common/util/index.js"
    },
    "./common/filters": {
      "types": "./dist/common/filters/index.d.ts",
      "default": "./dist/common/filters/index.js"
    },
    "./class-transformer": {
      "types": "./dist/class-transformer/index.d.ts",
      "default": "./dist/class-transformer/index.js"
    },
    "./validators": {
      "types": "./dist/validators/index.d.ts",
      "default": "./dist/validators/index.js"
    },
    "./typeorm": {
      "types": "./dist/typeorm/index.d.ts",
      "default": "./dist/typeorm/index.js"
    },
    "./modules": {
      "types": "./dist/modules/index.d.ts",
      "default": "./dist/modules/index.js"
    },
    "./modules/outbox": {
      "types": "./dist/modules/outbox/index.d.ts",
      "default": "./dist/modules/outbox/index.js"
    },
    "./logger": {
      "types": "./dist/logger/index.d.ts",
      "default": "./dist/logger/index.js"
    },
    "./logger/pino": {
      "types": "./dist/logger/pino/index.d.ts",
      "default": "./dist/logger/pino/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "default": "./dist/errors/index.js"
    },
    "./zod": {
      "types": "./dist/zod/index.d.ts",
      "default": "./dist/zod/index.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "pagination": [
        "dist/pagination/index.d.ts"
      ],
      "validators": [
        "dist/validators/index.d.ts"
      ],
      "typeorm": [
        "dist/typeorm/index.d.ts"
      ],
      "common/util": [
        "dist/common/util/index.d.ts"
      ],
      "common/filters": [
        "dist/common/filters/index.d.ts"
      ],
      "class-transformer": [
        "dist/class-transformer/index.d.ts"
      ],
      "modules": [
        "dist/modules/index.d.ts"
      ],
      "modules/outbox": [
        "dist/modules/outbox/index.d.ts"
      ],
      "logger": [
        "dist/logger/index.d.ts"
      ],
      "logger/pino": [
        "dist/logger/pino/index.d.ts"
      ],
      "errors": [
        "dist/errors/index.d.ts"
      ],
      "zod": [
        "dist/zod/index.d.ts"
      ]
    }
  },
  "dependencies": {
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "uuid": "^11.0.5"
  },
  "peerDependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/lib-storage": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/config": "^3.0.0 || ^4.0.0",
    "@nestjs/typeorm": "^10.0.0 || ^11.0.0",
    "fastify": "^4.0.0 || ^5.0.0",
    "nest-winston": "^1.10.2",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "typeorm": "^0.3.20",
    "winston": "^3.17.0",
    "winston-loki": "^6.1.3",
    "winston-transport": "^4.9.0",
    "zod": "^3.0.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "fastify": {
      "optional": true
    },
    "nestjs-pino": {
      "optional": true
    },
    "pino": {
      "optional": true
    },
    "pino-http": {
      "optional": true
    },
    "pino-pretty": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/testing": "^11.0.7",
    "@nestjs/typeorm": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "fastify": "^5.8.5",
    "jest": "^29.7.0",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "zod": "^4.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "setupFiles": [
      "<rootDir>/jest.setup.ts"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
